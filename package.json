{
    "name": "@liria24/og-image",
    "version": "1.3.3",
    "description": "OG image generation server",
    "bugs": {
        "url": "https://github.com/liria24/og-image/issues"
    },
    "license": "MIT",
    "author": "Liria",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/liria24/og-image.git"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/client.mjs",
            "types": "./dist/client.d.mts"
        },
        "./nuxt": {
            "import": "./dist/nuxt.mjs",
            "types": "./dist/nuxt.d.mts"
        }
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "prepare": "nitro prepare",
        "build:client": "tsdown",
        "build": "bun run build:client && nitro build",
        "dev": "nitro dev",
        "preview": "wrangler --cwd .output dev",
        "verify": "bun scripts/verify.ts",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "check": "bun run prepare && bun run typecheck && bun run lint && bun run fmt:check && bun run build && wrangler --cwd .output deploy --dry-run",
        "deploy": "bun run check && wrangler --cwd .output deploy",
        "prepublish": "bun run check"
    },
    "dependencies": {
        "ofetch": "^2.0.0-alpha.3"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^5.20260703.1",
        "@nuxt/kit": "^4.4.8",
        "@nuxt/schema": "^4.4.8",
        "@types/node": "^26.1.0",
        "bumpp": "^11.1.0",
        "http-status-codes": "^2.3.0",
        "nitro": "3.0.260610-beta",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.72.0",
        "oxlint-tsgolint": "^0.24.0",
        "takumi-js": "^2.0.0-rc.5",
        "taze": "^19.14.1",
        "tsdown": "^0.22.3",
        "typescript": "6.0.3",
        "valibot": "^1.4.2",
        "vitest": "^4.1.9",
        "wrangler": "^4.107.0"
    },
    "peerDependencies": {
        "@nuxt/kit": ">=3.0.0",
        "@nuxt/schema": ">=3.0.0"
    },
    "peerDependenciesMeta": {
        "@nuxt/kit": {
            "optional": true
        },
        "@nuxt/schema": {
            "optional": true
        }
    }
}
